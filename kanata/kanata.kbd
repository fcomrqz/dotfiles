(defcfg
  macos-dev-names-include ("HHKB-Classic")
)

(defsrc
  esc   1     2     3     4     5     6     7     8     9     0     -     =     \     grv
  tab   q     w     e     r     t     y     u     i     o     p     [     ]     bspc
  lctl  a     s     d     f     g     h     j     k     l     ;     '     ret
  lsft  z     x     c     v     b     n     m     ,     .     /     rsft  fn
        lmet  lalt                spc                   ralt  rmet
)

(defhands
  (left  tab q w e r t lctl a s d f g lsft z x c v b)
  (right y u i o p [ h j k l ; ' n m , . / rsft)
)

(deflayer base
  XX    XX    XX    XX    XX    XX     XX    XX    XX    XX    XX    XX    XX    XX    XX
  tab   q     w     e     r     t      y     @u    i     @o    p     [     XX    XX
  @esc  @a    @s    @d    @f    g      h     @j    @k    @l    @sc   '     XX
  grv   z     x     c     v     b      @n    m     ,     .     /     =     XX
        XX    XX                  @spc                   XX    XX
)

(deflayer space
  XX    XX    XX    XX    XX    XX     XX    XX    XX    XX    XX    XX    XX    XX    XX
  tab   @S-1  @S-2  @S-3  @S-4  @S-5   @S-6  @S-7  @S-8  @S-9  @S-0  @S--  XX    XX
  @caps 1     2     3     4     5      6     7     8     9     0     -     XX
  XX    \     f14   f15   S-\   prev  next   mute  vold  volu  pp    mctl  XX
        XX    XX                    XX                   XX    XX
)

(defalias
  a (tap-hold-opposite-hand-release 200 a lctl (same-hand tap) (timeout hold))
  s (tap-hold-opposite-hand-release 200 s lalt (same-hand tap) (timeout hold))
  d (tap-hold-opposite-hand-release 200 d lmet (same-hand tap) (timeout hold))
  f (tap-hold-opposite-hand-release 200 f lsft (same-hand tap) (timeout hold))

  j (tap-hold-opposite-hand-release 200 j rsft (same-hand tap) (timeout hold))
  k (tap-hold-opposite-hand-release 200 k rmet (same-hand tap) (timeout hold))
  l (tap-hold-opposite-hand-release 200 l ralt (same-hand tap) (timeout hold))
  sc (tap-hold-opposite-hand-release 200 ; rctl (same-hand tap) (timeout hold))

  esc (tap-hold 200 200 esc (multi lctl lalt lmet lsft))

  spc (tap-hold 200 200 spc (layer-toggle space))

  caps (caps-word 3000)

  n (fork (tap-hold 200 300 n (unicode ñ)) n (lsft lmet lalt lctl))
  u (tap-hold 200 300 u (unicode ü))
  o (tap-hold 200 300 o (unicode ö))

  S-1 (tap-hold 200 300 S-1 (macro A-1))
  S-2 (macro S-2)
  S-3 (macro S-3)
  S-4 (tap-hold 200 300 S-4 (macro S-A-2))
  S-5 (macro S-5)
  S-6 (macro S-6)
  S-7 (macro S-7)
  S-8 (macro S-8)
  S-9 (macro S-9)
  S-0 (macro S-0)
  S-- (macro S--)
)

(defoverrides
  (rctl f) (right)
  (rctl b) (left)
  (rctl d) (del)

  (ralt f) (ralt right)
  (ralt b) (ralt left)
  (ralt d) (ralt del)

  (lctl p) (up)
  (lctl n) (down)
  (lctl j) (ret)
  (lctl h) (bspc)

  (lalt p) (lalt up)
  (lalt n) (lalt down)
  (lalt j) (lalt ret)
  (lalt h) (lalt bspc)
  (lalt [) (])

  (lmet j) (lmet ret)
  (lmet h) (lmet bspc)

  (rmet tab) (f20)

  (lsft lmet h) (lsft lmet h)
)
